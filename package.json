{
  "name": "prompt-coach",
  "version": "0.1.0-beta.0",
  "description": "Local-first agent loop memory and meta-prompting workbench for Codex, Claude Code, and coding-agent workflows.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wlsdks/loopdeck.git"
  },
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=22 <25"
  },
  "bin": {
    "prompt-coach": "./dist/cli/index.js",
    "loopdeck": "./dist/cli/index.js",
    "pc-claude": "./dist/cli/pc-claude.js",
    "pc-codex": "./dist/cli/pc-codex.js"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    ".claude-plugin",
    "commands",
    "README.md",
    "README.ko.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "SUPPORT.md",
    "docs/PRD.md",
    "docs/PRD_PHASE2.md",
    "docs/ARCHITECTURE.md",
    "docs/EFFICIENCY_REVIEW.md",
    "docs/LEGAL_USAGE_GUIDE.md",
    "docs/TECH_SPEC.md",
    "docs/IMPLEMENTATION_PLAN.md",
    "docs/ADAPTERS.md",
    "docs/PLUGINS.md",
    "docs/superpowers/plans/2026-07-04-loopdeck-plugin-rename-plan.md",
    "docs/superpowers/plans/2026-07-04-loopdeck-plugin-rename-issue-slices.md",
    "docs/superpowers/plans/2026-07-04-loopdeck-claude-dual-namespace-decision.md",
    "docs/superpowers/plans/2026-07-04-loopdeck-mcp-server-name-decision.md",
    "docs/superpowers/plans/2026-07-04-loopdeck-deprecation-readiness.md",
    "docs/superpowers/plans/2026-07-04-loopdeck-next-runtime-value-slice.md",
    "docs/superpowers/plans/2026-07-04-loopdeck-runtime-id-inventory.json",
    "docs/BENCHMARK_V1.md",
    "docs/FEATURE_AUDIT_2026-05-02.md",
    "docs/PRD2_COMPLETION_AUDIT.md",
    "docs/NPM_PUBLISHING.md",
    "docs/PACKAGE_CONTENTS.md",
    "docs/PRE_PUBLISH_PRIVACY_AUDIT.md",
    "docs/RELEASE_CHECKLIST.md",
    "plugins",
    "integrations",
    "scripts/benchmark.mjs",
    "scripts/browser-e2e.mjs",
    "scripts/hook-binary-smoke.mjs",
    "scripts/mcp-elicitation-smoke.mjs",
    "scripts/mcp-coach-loop-smoke.mjs",
    "scripts/mcp-native-dialog-preflight.mjs",
    "scripts/quality-gate.mjs",
    "scripts/release-smoke.mjs",
    "scripts/ui-patrol.mjs"
  ],
  "scripts": {
    "build": "pnpm build:server && pnpm build:web",
    "build:server": "tsc -p tsconfig.json && node scripts/fix-bin-mode.mjs",
    "build:web": "vite build --config vite.web.config.ts",
    "clean": "rm -rf dist coverage",
    "format": "prettier --check package.json tsconfig.json tsconfig.web.json vite.web.config.ts vitest.config.ts \"scripts/**/*.mjs\" \"src/**/*.{ts,tsx,css}\" \".github/**/*.yml\"",
    "format:write": "prettier --write package.json tsconfig.json tsconfig.web.json vite.web.config.ts vitest.config.ts \"scripts/**/*.mjs\" \"src/**/*.{ts,tsx,css}\" \".github/**/*.yml\"",
    "benchmark": "pnpm build && node scripts/benchmark.mjs",
    "dev:web": "vite --config vite.web.config.ts",
    "e2e:browser": "pnpm build && node scripts/browser-e2e.mjs",
    "lint": "pnpm lint:types && pnpm lint:quality",
    "lint:quality": "node scripts/quality-gate.mjs",
    "lint:types": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "pnpm build",
    "prepare": "pnpm build",
    "prompt-coach": "node dist/cli/index.js",
    "setup": "pnpm prompt-coach setup --profile coach --register-mcp --open-web",
    "smoke:hooks": "pnpm build && node scripts/hook-binary-smoke.mjs",
    "smoke:mcp-coach-loop": "pnpm build && node scripts/mcp-coach-loop-smoke.mjs",
    "smoke:mcp-elicitation": "pnpm build && node scripts/mcp-elicitation-smoke.mjs",
    "smoke:mcp-native-dialog": "pnpm build && node scripts/mcp-native-dialog-preflight.mjs",
    "smoke:release": "pnpm build && node scripts/release-smoke.mjs",
    "test": "vitest run",
    "ui-patrol": "node scripts/ui-patrol.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "commander": "^14.0.3",
    "fastify": "^5.8.5",
    "recharts": "^3.8.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "lucide-react": "^1.14.0",
    "playwright": "^1.59.1",
    "prettier": "^3.5.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
