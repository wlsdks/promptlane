{
  "name": "looprelay",
  "version": "1.0.0",
  "description": "LoopRelay local continuity and evidence layer for long-running coding-agent loops.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wlsdks/looprelay.git"
  },
  "homepage": "https://github.com/wlsdks/looprelay",
  "bugs": {
    "url": "https://github.com/wlsdks/looprelay/issues"
  },
  "keywords": [
    "looprelay",
    "agent-continuity",
    "loop-engineering",
    "evidence",
    "local-first",
    "codex",
    "claude-code",
    "mcp",
    "worktrees"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=22.12 <25"
  },
  "bin": {
    "looprelay": "./dist/cli/index.js",
    "lr-claude": "./dist/cli/lr-claude.js",
    "lr-codex": "./dist/cli/lr-codex.js"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    ".claude-plugin",
    "commands",
    "README.md",
    "README.ko.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "SUPPORT.md",
    "docs/PRD.md",
    "docs/PRD_PHASE2.md",
    "docs/ARCHITECTURE.md",
    "docs/EFFICIENCY_REVIEW.md",
    "docs/LEGAL_USAGE_GUIDE.md",
    "docs/TECH_SPEC.md",
    "docs/IMPLEMENTATION_PLAN.md",
    "docs/ADAPTERS.md",
    "docs/LOOPRELAY.md",
    "docs/LOOPRELAY-RUNTIME-HISTORY.md",
    "docs/LOOPRELAY-RUNTIME-SURFACES.md",
    "docs/LOOP-SNAPSHOT-SCHEMA.md",
    "docs/AGENT-HARNESS.md",
    "docs/DOGFOOD_CODEX_CLAUDE_2026-07-05.md",
    "docs/DOGFOOD_WEB_USER_FLOW_2026-07-05.md",
    "docs/INSTRUCTION-FILES.md",
    "docs/PLUGINS.md",
    "docs/superpowers/plans/2026-07-04-looprelay-plugin-rename-plan.md",
    "docs/superpowers/plans/2026-07-04-looprelay-plugin-rename-issue-slices.md",
    "docs/superpowers/plans/2026-07-04-looprelay-claude-dual-namespace-decision.md",
    "docs/superpowers/plans/2026-07-04-looprelay-mcp-server-name-decision.md",
    "docs/superpowers/plans/2026-07-04-looprelay-deprecation-readiness.md",
    "docs/superpowers/plans/2026-07-04-looprelay-next-runtime-value-slice.md",
    "docs/superpowers/plans/2026-07-04-looprelay-runtime-id-inventory.json",
    "docs/superpowers/plans/2026-07-05-looprelay-95-quality-plan.md",
    "docs/superpowers/specs/2026-07-05-looprelay-repositioning-design.md",
    "docs/BENCHMARK_V1.md",
    "docs/benchmark-fixtures/real.example.json",
    "docs/FEATURE_AUDIT_2026-05-02.md",
    "docs/PRD2_COMPLETION_AUDIT.md",
    "docs/NPM_PUBLISHING.md",
    "docs/PACKAGE_CONTENTS.md",
    "docs/PRE_PUBLISH_PRIVACY_AUDIT.md",
    "docs/NATIVE_DIALOG_DOGFOOD_AUDIT_2026-07-05.md",
    "docs/RELEASE_STABILITY_EVIDENCE_2026-07-06.md",
    "docs/LOCAL_95_EVIDENCE_2026-07-06.md",
    "docs/PRODUCT_POSITIONING_EVIDENCE_2026-07-06.md",
    "docs/UI_PATROL_EVIDENCE_2026-07-06.md",
    "docs/UI_PATROL_SCHEDULE_READINESS_2026-07-06.md",
    "docs/CODEX_CLAUDE_LOCAL_INTEGRATION_EVIDENCE_2026-07-06.md",
    "docs/RELEASE_CHECKLIST.md",
    "plugins",
    "integrations",
    "scripts/benchmark.mjs",
    "scripts/benchmark-runner.mjs",
    "scripts/benchmark-fixtures.mjs",
    "scripts/benchmark-scores.mjs",
    "scripts/agent-setup-smoke.mjs",
    "scripts/browser-e2e.mjs",
    "scripts/first-coach-loop-dogfood.mjs",
    "scripts/loop-memory-approval-dogfood.mjs",
    "scripts/hook-binary-smoke.mjs",
    "scripts/mcp-elicitation-smoke.mjs",
    "scripts/mcp-coach-loop-smoke.mjs",
    "scripts/mcp-native-dialog-preflight.mjs",
    "scripts/mcp-native-dialog-approved.mjs",
    "scripts/quality-95-evidence.mjs",
    "scripts/npm-publish-preflight.mjs",
    "scripts/package-install-smoke.mjs",
    "scripts/npm-pack-output.mjs",
    "scripts/pack-dry-run.mjs",
    "scripts/quality-gate.mjs",
    "scripts/release-smoke.mjs",
    "scripts/ui-patrol.mjs"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm build:server && pnpm build:web",
    "build:server": "tsc -p tsconfig.json && node scripts/fix-bin-mode.mjs",
    "build:web": "vite build --config vite.web.config.ts",
    "clean": "rm -rf dist coverage",
    "format": "prettier --check package.json tsconfig.json tsconfig.web.json vite.web.config.ts vitest.config.ts \"scripts/**/*.mjs\" \"src/**/*.{ts,tsx,css}\"",
    "format:write": "prettier --write package.json tsconfig.json tsconfig.web.json vite.web.config.ts vitest.config.ts \"scripts/**/*.mjs\" \"src/**/*.{ts,tsx,css}\"",
    "benchmark": "node scripts/benchmark-runner.mjs",
    "dev:web": "vite --config vite.web.config.ts",
    "e2e:browser": "corepack pnpm build && node scripts/browser-e2e.mjs",
    "lint": "pnpm lint:format && pnpm lint:types && pnpm lint:quality",
    "lint:format": "pnpm format",
    "lint:quality": "node scripts/quality-gate.mjs",
    "lint:types": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "pack:dry-run": "node scripts/pack-dry-run.mjs",
    "prepack": "corepack pnpm build",
    "prepare": "corepack pnpm build",
    "looprelay": "node dist/cli/index.js",
    "setup": "pnpm looprelay setup --profile coach --register-mcp --open-web",
    "smoke:agent-setup": "corepack pnpm build && node scripts/agent-setup-smoke.mjs",
    "smoke:hooks": "corepack pnpm build && node scripts/hook-binary-smoke.mjs",
    "smoke:mcp-coach-loop": "corepack pnpm build && node scripts/mcp-coach-loop-smoke.mjs",
    "smoke:mcp-elicitation": "corepack pnpm build && node scripts/mcp-elicitation-smoke.mjs",
    "smoke:mcp-native-dialog": "corepack pnpm build && node scripts/mcp-native-dialog-preflight.mjs",
    "dogfood:mcp-native-dialog-approved": "corepack pnpm build && node scripts/mcp-native-dialog-approved.mjs",
    "dogfood:mcp-native-dialog-refusal": "corepack pnpm build && node scripts/mcp-native-dialog-approved.mjs",
    "dogfood:first-coach-loop": "corepack pnpm build && node scripts/first-coach-loop-dogfood.mjs",
    "dogfood:loop-memory-approval": "corepack pnpm build && node scripts/loop-memory-approval-dogfood.mjs",
    "dogfood:web-user-flow": "corepack pnpm e2e:browser",
    "evidence:quality": "node scripts/quality-95-evidence.mjs",
    "evidence:usefulness": "node scripts/usefulness-report.mjs",
    "evidence:real-task": "node scripts/usefulness-report.mjs reports/usefulness-real-task-pairs.json docs/assets/usefulness-real-task-results.svg reports/usefulness-real-task-summary.json --skip-readme",
    "evidence:codex-metrics": "node scripts/usefulness-codex-metrics.mjs",
    "evidence:participant-intake": "node scripts/usefulness-participant-intake.mjs",
    "npm-publish:preflight": "node scripts/npm-publish-preflight.mjs",
    "smoke:package-install": "node scripts/package-install-smoke.mjs",
    "smoke:release": "corepack pnpm build && node scripts/release-smoke.mjs",
    "test": "vitest run",
    "ui-patrol": "node scripts/ui-patrol.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "fastify": "^5.9.0",
    "recharts": "^3.9.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "0.28.1",
    "lucide-react": "^1.14.0",
    "playwright": "^1.59.1",
    "prettier": "^3.5.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.5"
  }
}
