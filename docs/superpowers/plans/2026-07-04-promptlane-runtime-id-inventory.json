{
  "schema_version": 1,
  "date": "2026-07-04",
  "purpose": "Compatibility inventory before PromptLane runtime id rename work.",
  "package": {
    "name": "promptlane",
    "bins": {
      "promptlane": "./dist/cli/index.js",
      "promptlane": "./dist/cli/index.js",
      "pl-claude": "./dist/cli/pl-claude.js",
      "pl-codex": "./dist/cli/pl-codex.js"
    },
    "repository": "https://github.com/wlsdks/promptlane.git"
  },
  "claude_code_plugin": {
    "manifest": ".claude-plugin/plugin.json",
    "manifest_name": "promptlane",
    "slash_namespace": "/promptlane:*",
    "command_files": [
      "./commands/buddy.md",
      "./commands/coach.md",
      "./commands/guard.md",
      "./commands/habits.md",
      "./commands/improve-last.md",
      "./commands/judge.md",
      "./commands/open.md",
      "./commands/score.md",
      "./commands/setup.md",
      "./commands/status.md"
    ]
  },
  "codex_plugin": {
    "manifest": "plugins/promptlane/.codex-plugin/plugin.json",
    "manifest_name": "promptlane",
    "display_name": "PromptLane",
    "install_path": "plugins/promptlane",
    "hook_install": "promptlane setup --profile coach --register-mcp --open-web"
  },
  "mcp": {
    "canonical_server_name": "promptlane",
    "command": "promptlane mcp",
    "docs": [
      "README.md",
      "README.ko.md",
      "docs/PLUGINS.md"
    ]
  },
  "invariants": [
    "Do not remove /promptlane:*.",
    "Do not rename package.json#name.",
    "Do not rename plugin ids.",
    "Do not remove the promptlane binary.",
    "Do not rename hook commands without hook binary compatibility smoke.",
    "Do not rename MCP server examples without an MCP compatibility decision."
  ],
  "privacy_exclusions": [
    "prompt bodies",
    "transcript text",
    "compact summaries",
    "raw paths",
    "API tokens",
    "provider credentials"
  ],
  "next_slice": "Rename compatibility issue slices complete; next implementation slice should return to product/runtime value."
}
